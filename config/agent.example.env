NODE_ENV=production
LOG_LEVEL=info

# Required manager endpoint.
MANAGER_API_URL=https://mqttmgmt.example.com
WSS_URL=

# Activation flow. Use the 24-character activation code provided by Rectrix in a separate email.
AGENT_ACTIVATION_CODE=

# Direct bootstrap flow. Use these if the manager already issued an agent id/token.
AGENT_ID=
AGENT_BOOTSTRAP_TOKEN=
AGENT_RUNTIME_TOKEN=
AGENT_ENV_FILE_PATH=/etc/rectrix-agent/agent.env

AGENT_VERSION=0.1.0
STATE_FILE=/var/lib/rectrix-agent/state.json
POLL_INTERVAL_MS=10000
HEARTBEAT_INTERVAL_MS=30000
HTTP_TIMEOUT_MS=15000
CONTROL_PLANE_MODE=http
CONTROL_PLANE_AUTH_MODE=token
WSS_CONNECT_TIMEOUT_MS=10000
WSS_PING_INTERVAL_MS=30000
WSS_PONG_TIMEOUT_MS=10000
WSS_FORCE_RECONNECT_MS=3600000
WSS_BACKOFF_INITIAL_MS=1000
WSS_BACKOFF_MAX_MS=30000

ACTIVATION_PATH=/public-agent/activate
ENROLL_PATH=/agent/enroll
HEARTBEAT_PATH=/agent/heartbeat
CAPABILITIES_PATH=/agent/capabilities
NEXT_JOB_PATH=/agent/jobs/next
JOB_EVENT_PATH_TEMPLATE=/agent/jobs/:jobId/events
JOB_COMPLETE_PATH_TEMPLATE=/agent/jobs/:jobId/complete

ALLOW_PACKAGE_OPERATIONS=true
ALLOWED_CONFIG_ROOTS=/etc/mosquitto,/etc/telegraf,/etc/systemd/system
ALLOWED_UNIT_PATTERNS="^mosquitto(?:@.+)?\\.service$,^telegraf(?:@.+)?\\.service$,^telegraf-.+\\.service$"

SUDO_BIN=/usr/bin/sudo
APT_GET_BIN=/usr/bin/apt-get
SYSTEMCTL_BIN=/usr/bin/systemctl
JOURNALCTL_BIN=/usr/bin/journalctl
INSTALL_BIN=/usr/bin/install
RM_BIN=/usr/bin/rm
